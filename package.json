{
  "name": "@qified/mono",
  "version": "0.12.0",
  "private": true,
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "engines": {
    "node": "^22.19.0 || >=24.0.0"
  },
  "type": "module",
  "description": "Qified Mono Repo",
  "scripts": {
    "test": "pnpm -r test",
    "test:ci": "pnpm -r test:ci",
    "test:services:start": "docker compose up -d",
    "test:services:stop": "docker compose down",
    "website:build": "docula build",
    "website:dev": "docula dev",
    "version:sync": "tsx scripts/version-sync.ts",
    "publish:qified": "pnpm recursive --filter 'qified' run build:publish",
    "publish:packages": "pnpm publish:qified && pnpm recursive --filter '!qified' run build:publish",
    "build": "pnpm --filter qified build && pnpm --filter '!qified' -r build",
    "clean": "pnpm -r clean"
  },
  "keywords": [],
  "author": "Jared Wray <me@jaredwray.com>",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.10",
    "docula": "^2.2.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
