{
  "name": "@qified/nats",
  "version": "0.10.0",
  "description": "NATS message provider for qified",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "biome check --write --error-on-warnings",
    "test": "pnpm lint && vitest run --coverage",
    "test:ci": "biome check --error-on-warnings && vitest run --coverage",
    "clean": "rimraf ./dist ./coverage",
    "build": "tsdown src/index.ts --format esm --format cjs --dts",
    "build:publish": "pnpm build && pnpm publish --access public --no-git-checks",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "qified",
    "nats",
    "message",
    "provider",
    "publish",
    "subscribe"
  ],
  "author": "Jared Wray <me@jaredwray.com>",
  "contributors": [
    "Santosh Bandichode <santoshg550@gmail.com>"
  ],
  "license": "MIT",
  "dependencies": {
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1",
    "hookified": "^2.1.1",
    "nats": "^2.29.3"
  },
  "peerDependencies": {
    "qified": "workspace:^"
  },
  "files": [
    "dist",
    "LICENSE"
  ]
}